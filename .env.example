# ============================================================
# VIGIE - Environment variables template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ============================================================
# SLACK APP CREDENTIALS
# ============================================================
# Get these from https://api.slack.com/apps -> your app -> Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here  # Required for Socket Mode

# ============================================================
# SLACK WORKSPACE (sandbox)
# ============================================================
# The sandbox workspace where Vigie runs (Reseau-Soligarde-Paris)
SLACK_WORKSPACE_NAME=Reseau-Soligarde-Paris
# Channel IDs (filled after sandbox setup)
SLACK_CELLULE_CRISE_CHANNEL_ID=
SLACK_SECTEUR_PREFIX=secteur-  # channels will be secteur-1, secteur-2, ...
SLACK_VOISINS_PREFIX=voisins-  # channels will be voisins-1, voisins-2, ...
SLACK_NUM_SECTORS=12

# ============================================================
# SLACK AI
# ============================================================
# Native Slack AI capabilities (if available in workspace)
# Otherwise, fallback to OpenAI
SLACK_AI_ENABLED=true
SLACK_AI_MODEL=claude-3-5-sonnet  # or gpt-4o, depending on availability

# Fallback LLM (used if Slack AI not available in sandbox)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ============================================================
# MCP SERVER
# ============================================================
# Transport: "stdio" for local testing, "sse" or "streamable-http" for production
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SERVER_TOKEN=your-mcp-server-auth-token  # shared secret for Slack bot <-> MCP

# ============================================================
# REAL-TIME SEARCH API
# ============================================================
# Slack Real-Time Search API endpoint (provided by Slack platform)
RTS_API_ENDPOINT=
RTS_API_KEY=
RTS_CACHE_TTL_SECONDS=1800  # 30 min cache in alert orange
RTS_REFRESH_INTERVAL_SECONDS=1800

# ============================================================
# EXTERNAL DATA SOURCES
# ============================================================
# Météo-France API (public, vigilance alerts)
# https://portail-api.meteofrance.fr/
METEO_FRANCE_API_KEY=
METEO_FRANCE_VIGILANCE_URL=https://public-api.meteofrance.fr/public/DPVigilance/v1/

# NWS Weather API (US fallback, public, no key)
NWS_API_BASE=https://api.weather.gov
NWS_ALERTS_ENDPOINT=/alerts/active

# OpenStreetMap Overpass API (POIs: pharmacies, hospitals, water points)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# INSEE (public demographic data)
INSEE_API_BASE=https://api.insee.fr

# ============================================================
# CACHE (Redis optional, SQLite fallback)
# ============================================================
REDIS_URL=redis://localhost:6379/0  # leave empty to use SQLite cache
SQLITE_CACHE_PATH=./vigie_cache.db

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json or text
LOG_FILE=./logs/vigie.log

# ============================================================
# DEMO / SIMULATION
# ============================================================
# Number of simulated beneficiaries (default: 50)
VIGIE_NUM_BENEFICIARIES=50
# Number of simulated volunteers (default: 12)
VIGIE_NUM_VOLUNTEERS=12
# Heat threshold (°C) for triggering vigilance orange
VIGIE_HEAT_THRESHOLD_ORANGE=32
VIGIE_HEAT_THRESHOLD_RED=36
# Demo scenario file
VIGIE_SCENARIO_PATH=./mcp_server/data/scenario_canicule_juillet.json

# ============================================================
# DEPLOYMENT
# ============================================================
# Railway / Render environment
PORT=3000  # Slack Bolt app port
RAILWAY_VOLUME_MOUNT_PATH=/data  # if deploying on Railway with volume

# ============================================================
# SECURITY
# ============================================================
# Allowed user IDs (sandbox demo only) — leave empty to allow all
VIGIE_ALLOWED_USER_IDS=
# Encryption key for beneficiary registry (if needed)
VIGIE_DATA_ENCRYPTION_KEY=
