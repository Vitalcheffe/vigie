Thumbs.db

# ---- Project specific ----
# Never commit real beneficiary data
mcp_server/data/real_*
!mcp_server/data/beneficiaries.json
!mcp_server/data/volunteers.json
!mcp_server/data/sectors.json
!mcp_server/data/scenario_canicule_juillet.json

# Sandbox credentials (filled per environment)
sandbox_credentials.json

# Video editing projects (large files)
*.prproj
*.fcpbundle
*.drp

# Final video exports go to /download
download/

# ---- Keep these tracked ----
!.env.example
!.gitignore
